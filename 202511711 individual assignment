#include <iostream>
#include <vector>
#include <cstdlib>
#include <ctime>

using namespace std;

int main() {
    srand(time(0)); // 
    
    // 1. Variable to store the chosen number (Random)
    int secretNumber = (rand() % 10) + 1; /
    
    // 2. Variable to store the user's input
    int playerGuess = 0;
    
    // 3. Empty array (vector) to keep all numbers entered by the user
    vector<int> attempts;
    
    cout << "\n";
    cout << "╔════════════════════════════════╗" << endl;
    cout << "║   SECRET NUMBER GUESSING GAME   ║" << endl;
    cout << "╚════════════════════════════════╝" << endl;
    cout << "\nCan you find the secret number between 1 and 10?" << endl;
    cout << "Let's see how many tries it takes you!" << endl << endl;
    
    // While loop that continues as long as the user's guess is not equal to the chosen number
    while (playerGuess != secretNumber) {
        cout << "What is your guess? ";
        cin >> playerGuess;
        
        // Validate input
        if (cin.fail()) {
            cin.clear();
            cin.ignore(10000, '\n');
            cout << "⚠️  Please enter a valid number!" << endl << endl;
            continue;
        }
        
        // Store the value in the array/list
        attempts.push_back(playerGuess);
        
        // If / else statements to compare the user's guess with the chosen number
        if (playerGuess > secretNumber) {
            cout << "Too high ↓" << endl << endl;
        }
        else if (playerGuess < secretNumber) {
            cout << "Too low ↑" << endl << endl;
        }
        else {
            cout << "Correct! ✓" << endl << endl;
        }
    }
    
    // Use a for loop to display all guesses stored in the array/list
    cout << "╔════════════════════════════════╗" << endl;
    cout << "║     YOUR GUESSING HISTORY      ║" << endl;
    cout << "╚════════════════════════════════╝" << endl;
    cout << "Number of attempts: " << attempts.size() << endl << endl;
    
    for (int i = 0; i < attempts.size(); i++) {
        cout << "Try #" << (i + 1) << " → " << attempts[i] << endl;
    }
    
    cout << "\n🎉 Amazing! You found the secret number: " << secretNumber << endl;
    cout << "You needed " << attempts.size() << " attempt(s)!" << endl;
    
    // Performance message
    if (attempts.size() == 1) {
        cout << "🌟 Perfect! First try genius!" << endl;
    }
    else if (attempts.size() <= 3) {
        cout << "👏 Excellent! Very good job!" << endl;
    }
    else if (attempts.size() <= 5) {
        cout << "✨ Not bad! You got it!" << endl;
    }
    else {
        cout << "💪 Keep practicing, you'll get better!" << endl;
    }
    
    cout << "\n";
    
    return 0;
}
